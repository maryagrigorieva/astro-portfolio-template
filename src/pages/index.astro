---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import About from '../components/About.astro';
import Timeline from '../components/Timeline.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Cases from '../components/Cases.astro';
import Experience from '../components/Experience.astro';
import { Image } from 'astro:assets';
import profilePhoto from '../assets/images/profile.jpg';
import { getInfo } from '../lib/content-parser';

const info = getInfo();
const useTimeline = (info.experience_view ?? 'timeline') === 'timeline';

const metaTitle = `${info.name} — ${info.role}`;
const metaDescription = info.tagline;
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <Header />

  <main>
    <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
    <section class="mx-auto max-w-5xl px-4 pb-24 pt-20 sm:px-6 sm:pt-28">
      <div class="flex flex-col items-center gap-12 md:flex-row md:items-center md:gap-16">
        <!-- Avatar -->
        <div class="shrink-0">
          <div
            class="overflow-hidden rounded-full"
            style="width: 176px; height: 176px; border: 2px solid var(--border);"
          >
            <Image
              src={profilePhoto}
              alt={`Фото ${info.name}`}
              width={176}
              height={176}
              class="h-full w-full object-cover object-top"
              loading="eager"
            />
          </div>
        </div>

        <!-- Text content -->
        <div class="flex flex-col gap-5 text-center md:text-left">
          <!-- Role badge -->
          <div>
            <span
              class="inline-block rounded-full px-3 py-1 text-xs font-medium"
              style="background-color: var(--accent-light); color: var(--accent);"
            >
              {info.role}
            </span>
          </div>

          <!-- Name -->
          <h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl" style="color: var(--text);">
            {info.name}
          </h1>

          <!-- Tagline -->
          <p class="max-w-xl text-base leading-relaxed sm:text-lg" style="color: var(--text-muted);">
            {info.tagline}
          </p>

          <!-- Location -->
          <p class="flex items-center justify-center gap-1.5 text-sm md:justify-start" style="color: var(--text-subtle);">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            {info.location}
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap justify-center gap-3 pt-2 md:justify-start">
            <a
              href={`https://t.me/${info.contacts.telegram.replace('@', '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors"
              style="background-color: var(--accent);"
              onmouseover="this.style.backgroundColor='var(--accent-hover)'"
              onmouseout="this.style.backgroundColor='var(--accent)'"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
              Связаться
            </a>

            <a
              href="/cv.pdf"
              download
              class="inline-flex items-center gap-2 rounded-lg border px-5 py-2.5 text-sm font-semibold transition-colors"
              style="border-color: var(--border); color: var(--text-muted);"
              onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"
              onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" x2="12" y1="15" y2="3"></line>
              </svg>
              Скачать CV
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Section placeholders ─────────────────────────────────────────── -->

    <!-- ─── О себе ───────────────────────────────────────────────────────────── -->
    <section id="about" class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
      <!-- Section heading -->
      <h2
        class="fade-up mb-12 text-2xl font-bold tracking-tight sm:text-3xl"
        style="color: var(--text);"
      >
        О себе
      </h2>

      <!-- Bio text -->
      <About />

      <!-- Career timeline (only when experience_view = "timeline") -->
      {useTimeline && (
        <div class="mt-16">
          <h3
            class="fade-up mb-10 text-lg font-semibold"
            style="color: var(--text);"
          >
            Карьерный путь
          </h3>
          <Timeline />
        </div>
      )}

      <!-- Skills -->
      <div class="mt-16">
        <h3
          class="fade-up mb-8 text-lg font-semibold"
          style="color: var(--text);"
        >
          Навыки
        </h3>
        <Skills />
      </div>
    </section>

    <!-- ─── Проекты ───────────────────────────────────────────────────────────── -->
    <section id="projects" class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
      <h2
        class="fade-up mb-12 text-2xl font-bold tracking-tight sm:text-3xl"
        style="color: var(--text);"
      >
        Проекты
      </h2>
      <Projects />
    </section>

    <!-- ─── Кейсы ─────────────────────────────────────────────────────────────── -->
    <section id="cases" class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
      <h2
        class="fade-up mb-12 text-2xl font-bold tracking-tight sm:text-3xl"
        style="color: var(--text);"
      >
        Кейсы
      </h2>
      <Cases />
    </section>

    <!-- ─── Опыт работы (only when experience_view = "cards") ──────────────── -->
    {!useTimeline && (
      <section id="experience" class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
        <h2
          class="fade-up mb-12 text-2xl font-bold tracking-tight sm:text-3xl"
          style="color: var(--text);"
        >
          Опыт работы
        </h2>
        <Experience />
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>
